# Confluence
CONFLUENCE_DOMAIN=wiki.devops.io
POSTGRES_DB=confluence
POSTGRES_USER=confluence
POSTGRES_PASSWORD=change-me-db
TZ=Asia/Shanghai

# HTTPS 由外部 Nginx 终结；compose 内 nginx 默认关闭，仅暴露 8090 HTTP。
# 若启用 compose 内 nginx 并需 TLS，取消注释并放入 config/ssl/：
# SSL_CERTIFICATE=devops.io.crt
# SSL_CERTIFICATE_KEY=devops.io.key
