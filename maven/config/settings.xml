<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">

  <!-- 复制到 ~/.m2/settings.xml，或 mvn -s config/settings.xml -->
  <!-- 本机 hosts: 127.0.0.1 maven.devops.com -->

  <servers>
    <server>
      <id>nexus</id>
      <username>admin</username>
      <password>change-me-after-first-login</password>
    </server>
    <server>
      <id>nexus-releases</id>
      <username>admin</username>
      <password>change-me-after-first-login</password>
    </server>
    <server>
      <id>nexus-snapshots</id>
      <username>admin</username>
      <password>change-me-after-first-login</password>
    </server>
  </servers>

  <mirrors>
    <mirror>
      <id>nexus</id>
      <name>Nexus Maven Public</name>
      <url>http://maven.devops.com:8081/repository/maven-public/</url>
      <mirrorOf>*</mirrorOf>
    </mirror>
  </mirrors>

  <profiles>
    <profile>
      <id>nexus</id>
      <repositories>
        <repository>
          <id>nexus</id>
          <url>http://maven.devops.com:8081/repository/maven-public/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>true</enabled></snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>nexus</id>
          <url>http://maven.devops.com:8081/repository/maven-public/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>true</enabled></snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>nexus</activeProfile>
  </activeProfiles>
</settings>
