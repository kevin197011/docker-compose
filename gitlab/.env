# Image versions (pin for production; bump after reading GitLab release notes)
GITLAB_CE_VERSION=18.11.6-ce.0
GITLAB_RUNNER_VERSION=alpine-v18.11.4
POSTGRES_VERSION=17-alpine
REDIS_VERSION=7-alpine

# GitLab access
GITLAB_URL=https://gitlab.devops.com
GITLAB_HTTP_PORT=80
GITLAB_HTTPS_PORT=443
GITLAB_SSH_PORT=2222
# HTTPS — demo certs in ./certs/ (replace for real production)
GITLAB_LISTEN_HTTPS=true
GITLAB_REDIRECT_HTTP_TO_HTTPS=true
GITLAB_SSL_CERT=gitlab.devops.com.crt
GITLAB_SSL_KEY=gitlab.devops.com.key
# Auto-generated by bootstrap.sh (openssl rand -hex 16)
GITLAB_ROOT_PASSWORD=8698516327bc2621fdbf86705bf29073
TZ=Asia/Shanghai

# PostgreSQL (GitLab requires database name gitlabhq_production)
POSTGRES_USER=gitlab
# Auto-generated by bootstrap.sh
POSTGRES_PASSWORD=9b666a5f9cead966996cc8b81718051f
POSTGRES_DB=gitlabhq_production

# Redis (shared password for all three Redis instances)
# Auto-generated by bootstrap.sh (hex only, safe for Redis URLs)
GITLAB_REDIS_PASSWORD=9335caae3f643c8ad5d7a4c27e56686f

# Performance tuning (adjust to host RAM/CPU; 16GB host baseline)
GITLAB_PUMA_WORKERS=4
GITLAB_SIDEKIQ_CONCURRENCY=20

# Runner — CI 内网走 HTTPS（与 external_url 域名一致）
GITLAB_INTERNAL_URL=https://gitlab.devops.com
